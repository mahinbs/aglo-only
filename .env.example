# ---------------------------------------------------------------------------
# algo-only frontend .env.example
# ---------------------------------------------------------------------------
# Use the SAME Supabase project as chartmate-trading-widget.

# Required
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-publishable-key

# Recommended: BFF base URL (used for dashboard summary, broker connect, options proxy)
# If empty, frontend falls back to direct browser calls where supported.
VITE_ALGO_ONLY_BFF_URL=http://localhost:8010

# Optional fallback: direct browser -> chartmate-options-api (if not using BFF proxy)
# Must allow this frontend origin in chartmate-options-api CORS.
# VITE_OPTIONS_API_URL=http://127.0.0.1:8001

# Optional display: INR/USD toggle (numeric factor INR → USD)
# VITE_USD_PER_INR=0.012

# --- Vercel / CI (set in dashboard, not in .env for local) ---
# CHARTMATE_WIDGET_REPO=https://github.com/yourorg/chartmate-trading-widget.git
# CHARTMATE_WIDGET_SRC=/absolute/path/to/chartmate-trading-widget/src
